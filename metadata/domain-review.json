{
  "repo": "vector-sys-fd-lens",
  "language": "R",
  "category": "Systems programming",
  "goal": "Build an R toolkit that studies fd behavior through negative fixtures, with human-readable error snapshots and no credentials or hosted services.",
  "review_model": {
    "terms": [
      "allocation pressure",
      "dirty state",
      "guard slack",
      "layout drift"
    ],
    "lanes": [
      "ship",
      "watch",
      "hold"
    ],
    "score": "signal * 2 + slack + confidence - drag * 3",
    "purpose": "surface the domain-specific cases that need the most careful review"
  },
